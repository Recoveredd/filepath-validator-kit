{
  "name": "filepath-validator-kit",
  "version": "0.1.0",
  "description": "Validate file paths with portable, POSIX, or Windows diagnostics.",
  "keywords": [
    "filepath",
    "file-path",
    "path-validation",
    "filename",
    "windows-path",
    "posix-path",
    "diagnostics",
    "typescript",
    "browser",
    "developer-tools"
  ],
  "type": "module",
  "sideEffects": false,
  "license": "MPL-2.0",
  "author": "Recoveredd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Recoveredd/filepath-validator-kit.git"
  },
  "bugs": {
    "url": "https://github.com/Recoveredd/filepath-validator-kit/issues"
  },
  "homepage": "https://github.com/Recoveredd/filepath-validator-kit#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
